[Unit]
Description=E-Ticaret Vite Frontend Server
After=network.target eticaret-backend.service

[Service]
Type=simple
User=xserio
WorkingDirectory=/home/xserio/e_ticaret_projesi/frontend
Environment="PATH=/home/xserio/.nvm/versions/node/v24.11.1/bin:/usr/bin"
Environment="NODE_ENV=development"
ExecStart=/home/xserio/.nvm/versions/node/v24.11.1/bin/npm run dev -- --host 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
